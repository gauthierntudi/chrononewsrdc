APP_NAME="Chrono News"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lubumbashi

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=chrononews
DB_USERNAME=root
DB_PASSWORD=root

# DB_CONNECTION=sqlite (dev rapide sans MySQL)

SITE_NAME="Chrono News"
SITE_URL=http://localhost:8000
SEED_SUPERADMIN_EMAIL=admin@fintechmedias.cd

ARTICLE_DEFAULT_PRICE=1.00
PAYMENT_CURRENCY=USD
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

FLEXPAY_MERCHANT=
# Mettre entre guillemets si le token contient "Bearer " (espace obligatoire)
FLEXPAY_TOKEN=
FLEXPAY_CALLBACK_SECRET=

MAXICASH_MERCHANT_ID=
MAXICASH_MERCHANT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=local
MEDIA_LOCAL_ROOT=
MEDIA_LOCAL_PREFIX=/publication
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.fintechmedias.cd
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@chrononews.web
MAIL_FROM_NAME="${APP_NAME}"

# Réseaux sociaux (emails & footer)
# SOCIAL_FACEBOOK=
# SOCIAL_TWITTER=
# SOCIAL_INSTAGRAM=
# SOCIAL_LINKEDIN=
# SOCIAL_YOUTUBE=
# MAIL_CONTACT_ADDRESS=contact@fintechmedias.cd

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_MEDIA_ROOT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Racine du projet (optionnel — monorepo local avec legacy à côté)
# CHRONONEWS_ROOT=/chemin/vers/CHRONONEWS
# MEDIA_LOCAL_ROOT=/chemin/vers/CHRONONEWS/publication

VITE_APP_NAME="${APP_NAME}"
